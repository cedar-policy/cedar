entity String = {
  realContent: __cedar::String
};

entity User = {
  active: __cedar::Bool,
  contact: {
    address: {
      city: String,
      street: String,
      zipcode: String
    },
    email: String,
    phone?: String
  },
  permissions: Set<__cedar::String>
};

action "updateContact" appliesTo {
  principal: [User],
  resource: [User],
  context: {
    newtypeReason: String,
    reason: __cedar::String,
    timestamp: __cedar::Long
  }
};
